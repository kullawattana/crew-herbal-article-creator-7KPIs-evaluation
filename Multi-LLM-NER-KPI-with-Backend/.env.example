# Multi-LLM NER Backend - Environment Variables
# Copy this file to .env and fill in your API keys

# Server Configuration
PORT=3000
NODE_ENV=development

# Anthropic Claude API
# Get your key from: https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI GPT API
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# Google Gemini API
# Get your key from: https://aistudio.google.com/api-keys
GOOGLE_API_KEY=xxxxx

# Groq API (for Llama models)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxx

# Optional: Enable specific providers only
# ENABLED_PROVIDERS=anthropic,openai,google,groq

# Optional: Rate limiting
# MAX_REQUESTS_PER_MINUTE=60

# Optional: Logging
# LOG_LEVEL=info
